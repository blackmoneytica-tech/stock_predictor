# Required
FRED_API_KEY=
# Alpha Vantage HISTORICAL_OPTIONS — 무료 25 req/day, 5 req/min
# 발급: https://www.alphavantage.co/support/#api-key (이메일 입력 20초)
# 백테스트에서 옵션 모듈 활성화의 유일한 무료 경로
ALPHA_VANTAGE_KEY=

# Marketdata.app — 옵션 데이터 정확 (yfinance OI=0/IV=placeholder 문제 해결)
# 무료 100 req/day, 이메일 가입: https://www.marketdata.app/
# 장 closed/주말에도 마지막 EOD OI/IV 정확하게 반환
MARKETDATA_KEY=

# Recommended (paid — 무제한 옵션 데이터)
POLYGON_API_KEY=
BARCHART_API_KEY=

# Optional (알림)
SMTP_SERVER=smtp.gmail.com
SMTP_USER=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

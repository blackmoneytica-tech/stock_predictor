# 🔐 Streamlit Cloud Secrets 예시
#
# 실제 등록 위치: Streamlit Cloud UI → App settings → Secrets
# 이 파일은 형식 가이드 일뿐 (실제 값은 입력 X — Git에 commit 금지)

# ── 분석 API 키 ─────────────────────────
FRED_API_KEY = "..."
ALPHA_VANTAGE_KEY = "..."
FINNHUB_KEY = "..."
MARKETDATA_KEY = "..."          # CBOE primary라 옵션. 없어도 작동
SEC_USER_AGENT = "stock_predictor your.email@example.com"

# ── 로그인 비밀번호 (간단 보호) ──────────
APP_PASSWORD = "your_strong_password_here"

# ── trade-journal 연동 (옵션) ───────────
TRADE_JOURNAL_URL = "https://trade-journal-1dv.pages.dev"
AUTH_TOKEN = "..."
